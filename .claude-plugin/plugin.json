{
  "name": "everyrow",
  "description": "Give Claude Code a research team. Forecast, score, classify, or research every row of a dataset.",
  "version": "0.5.0",
  "author": {
    "name": "FutureSearch"
  },
  "repository": "https://github.com/futuresearch/everyrow-sdk",
  "mcpServers": {
    "everyrow": {
      "command": "uvx",
      "args": ["everyrow-mcp"],
      "env": {
        "EVERYROW_API_KEY": "${EVERYROW_API_KEY}"
      }
    }
  }
}
